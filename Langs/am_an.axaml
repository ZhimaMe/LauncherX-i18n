    <sys:String x:Key="ContentValidationFailed">Iab Ihs Gnehz Nay Gnor Ien</sys:String>
    <sys:String x:Key="BlockCausedGameCrash">Iuk Gneb Ix Uoy Ihz Oad Iauk Gnaf Gnid Et</sys:String>
    <sys:String x:Key="EntityCausedGameCrash">Iuk Gneb Ix Uoy Ihz Oad It Ihs Gnid Et</sys:String>
    <sys:String x:Key="LogFileNotFound">Naij New Ihz Ir Ed Ix Nef Gnog Ek Oad Oahz Uoy Iem</sys:String>

    <sys:String x:Key="NoEnoughMemoryDetail">Minecraft Gnix Nuy Ux Ij Af Uw，Oag Oug Ihz Iep Ix Uoy Ouh Uz Ub Nuc Ien Ed Ix Uoy Ieg Iep Nef In Iew Niy Ihs Gnen Ek。Nuc Ien Ed Iep Nef Ix Uoy Aij Gnez Oug Gnot Iy Ek In、Ihz Iac Ed Oag Uiq Oay Uhc Nahs、ModIt New Euj Eij Ial Gniy Gnaug Eh。Gnoy Ouz Iq Ub Uod Af Gnaf Eix Ehz Oug Ur，Naij Naur At Iq Ib Naug Naiq Ix Uoy Iaz Ihs Gnahc Iy Ek In，Oan Naid Iat Nauh Vl Oak Ehz Ouh。</sys:String>
    <sys:String x:Key="NoEnoughMemory32Detail">Gnoy Ihs Iaz Gnehz In Ial Iq Nak 32 Ed Iew Java，Ihz Oad Gnen Ek Ehz Minecraft Oug Oahc Gnoy Ihs Af Uw 1GB Nuc Ien Ed，Iuk Gneb Ihz Oad。It New Eg Ehz Euj Eij Oay，Ed Ihz Ehs Gnod Iq Iaz Gniq Java Oad Nauh Eiq Gnohz Ez Naux 64 Ed Iew Java，Ix Uoy Gnod Iq Iaz Uoh Nar。Gnauhz Na Uoy Iem In Oug Ur 64 Ed Iew Java，Ij Naid Naim Eij Ihz Ehs Ix Uoy Iaz Iy Ek [Uq Ouh Java] Gnauhz Na Gnix Nij Ial。</sys:String>
    <sys:String x:Key="JavaVersionTooHighDetail">Ed Gnoy Ihs In Uy Uoy Java Oag Oug Neb Nab，El Iuk Gneb Gnij Iy Uh Is Ix Uoy。It New Eg Ehz Euj Eij El Iew，Ed Ihz Ehs Gnod Iq Iaz Gniq Java Ed Neb Nab Id Oaij Oad Nauh Eiq Gnohz Ez Naux Java，Ix Uoy Gnod Iq Iaz Uoh Nar。Gnauhz Na Uoy Iem In Oug Ur Java，Ij Naid Naim Eij Ihz Ehs Ix Uoy Iaz Iy Ek [Uq Ouh Java] Gnauhz Na Gnix Nij Ial。</sys:String>
    <sys:String x:Key="UnsupportedJavaVersionDetail">Ed Gnoy Ihs Naiq Gnad In Java Gnor Naij Ub Ix Uoy Uy。Ed Ihz Ehs Gnod Iq Iaz Gniq Java Ed Ihs Eh Oad Nauh Eiq Gnohz Ez Naux Java，Ix Uoy Gnod Iq Iaz Uoh Nar。Gnauhz Na Uoy Iem In Oug Ur Java，Ij Naid Naim Eij Ihz Ehs Ix Uoy Iaz Iy Ek [Uq Ouh Java] Gnauhz Na Gnix Nij Ial。</sys:String>
    <sys:String x:Key="JdkUseDetail">El Gnoy Ihs Uy Uoy JDK Ouh Java Oag Oug Neb Nab，El Iuk Gneb Ix Uoy。It New Eg Ehz Euj Eij El Iew，Ed Ihz Ehs Gnod Iq Iaz Gniq Java Oad Nauh Eiq Gnohz Ez Naux JRE，Ix Uoy Gnod Iq Iaz Uoh Nar。</sys:String>
    <sys:String x:Key="OpenJ9UseDetail">Gnoy Ihs Iew Niy Ix Uoy OpenJ9 El Iuk Gneb Re。It New Eg Ehz Euj Eij El Iew，Ed Ihz Ehs Gnod Iq Iaz Gniq Java Ief Oad Nauh Eiq Gnohz Ez Naux OpenJ9 Ed Java，Ix Uoy Gnod Iq Iaz Uoh Nar。</sys:String>
    <sys:String x:Key="UnsupportedIntelDriverDetail">Ak Naix Il Ud Gnoy Ihs Iew Ouh It New Iaz Nuc Gnod Uq Ak Naix Ed In，Gnix Nuy Gnahc Gnehz Af Uw Ix Uoy Ihz Oad。It New Eg Ehz Euj Eij El Iew，Gnod Iq Iaz Ihs Gnahc Gniq LauncherX Eh Minecraft Ihs Ub Re Ak Naix Il Ud Gnoy Ihs Ihs Intel Naix Eh。Iaz Nuc Nar Gner It New Oug Ur，Neb Nab Gnahc Uhc Oad Iut Iuh Ouh Neb Nab Nix Iuz Oad Ij Gnehs Gnod Uq Ak Naix Gnaij Ihs Gnahc Gniq。Iaz Nuc Nar Gner It New Oug Ur，Gnoy Ihs Ihs Gnahc Iy Ek Java8 Neb Nab Id Gneg Ouh。Euj Eij Af Uw Nar Iy It New Oug Ur，Ak Naix Ed Oah Gneg Gnen Gnix Iauk Iy Nauh Gneg Vl Oak Oay Ux Gnen Ek Em An。</sys:String>

    <sys:String x:Key="VideoDriverErrorDetail">It New Iaz Nuc Gnod Uq Ak Naix Ed In，Gnix Nuy Gnahc Gnehz Af Uw Ix Uoy Ihz Oad。It New Eg Ehz Euj Eij El Iew，Neb Nab Gnahc Uhc Oad Iut Iuh Ouh Neb Nab Nix Iuz Oad Ij Gnehs Gnod Uq Ak Naix Gnaij Ihs Gnahc Gniq，Ix Uoy Gnod Iq Iaz Uoh Nar。Iaz Nuc Nar Gner It New Oug Ur，Gnoy Ihs Ihs Gnahc Iy Ek Java8 Neb Nab Id Gneg Ouh。Euj Eij Af Uw Nar Iy It New Oug Ur，Ak Naix Ed Oah Gneg Gnen Gnix Iauk Iy Nauh Gneg Vl Oak Oay Ux Gnen Ek Em An。</sys:String>

    <sys:String x:Key="ModCausedGameCrashDetail">Iuk Gneb Ix Uoy El Ihz Oad Uz Om Eg Oud Ouh Eg Iy Ed Gnohz Ix Uoy Ed Gnod Iq Naiq Gnad Nin，Ix Nix Naug Gnaix Ed Iuk Gneb Uz Om Ihz Oad Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Iy Ek Nin，Uz Om Eix Ehz Nauh It Ihs Ouh Gnoy Nij Ihs Naz Ihs Gnahc Gnib。</sys:String>
    <sys:String x:Key="DecompressedModDetail">El Ous Ay Eij Ieb Naij New Uz Om Uy Uoy，Gnix Nuy Ux Ij Af Uw Ix Uoy Ihz Oad。It New Eg Ehz Euj Eij El Iew，Ur Gnaf Naij New Uz Om Eg Gnehz Gnaij Gniq [mods] Gnohz Aij Naij New，At Ous Ay Eij Oay Ub Re。Naij New Uz Om El Ay Eij Gnij Iy Oug Ur，Gnoc Iq Gnaij Gniq [mods] Uhc Nahs Gnohz Aij Naij New，Ix Uoy Gnod Iq Iaz Uoh Nar。</sys:String>
    <sys:String x:Key="IncorrectModConfigDetail">Iab Ihs Gnod Iq El Ihz Oad Euq Gnehz Ub Naij New Ihz Iep Eg Oud Ouh Eg Iy Ed Uz Om，Gnehc Gnim Naij New Ihz Iep Ed It Uj Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Iy Ek Nin，Uw Ouc Ed At Gnehz Uix Gnib。</sys:String>
    <sys:String x:Key="ModMixinFailedDetail">Iab Ihs Gnod Iq El Ihz Oad Iab Ihs Ur Uhz Uz Om Eg Oud Ouh Eg Iy，Uz Om Ed Ihc Ihz Neb Nab Ix Uoy Naiq Gnad Uohs Ub Ihs Ouh Uz Om Ed It New Iaz Nuc El Gnoy Ihs Nin Ehz Iew Iy Gnahc Gnot Ehz。Ix Nix Uz Om Ed It Uj Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Iy Ek Nin。</sys:String>
    <sys:String x:Key="ModLoaderErrorDetail">Uw Ouc Eg Oud Ouh Eg Iy El Oag Oab Iq Iaz Aij Uz Om，Niy Nauy It Uj Ed Ouc Oab Nak Ahc Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Iy Ek Nin。</sys:String>
    <sys:String x:Key="ModInitFailedDetail">Iaz Aij Ux Ij Af Uw Ix Uoy Ihz Oad Iab Ihs Auh Ihs Uhc Uz Om Eg Oud Ouh Eg Iy。Ix Nix Uw Ouc Naug Gnaix Ed Uz Om Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Gniq。</sys:String>
    <sys:String x:Key="ModIdExceededDetail">Oud Iat Gnail Uhs Uz Om Ed Gnauhz Na In，Ed Ix Uoy El Uhc Oahc ID Ihz Naix，Iuk Gneb Ix Uoy Ihz Oad。It New Eg Ehz Euj Eij El Iew，Uz Om Uf Uix Eix Iy Gnauhz Na Ihs Gnahc Iy Ek In，Ur JEID，Uz Om Gnix Ad Eix Iy Uhc Nahs Ouh。Gnail Uhs Ed Uz Om Oahs Naij In Uhz Gnab Iy Ek Ehz，Gnid New Aij Gneg Ix Uoy Gnar Gnib。</sys:String>
    <sys:String x:Key="DuplicateModDetail">Uz Om Ed Gnot Gnaix Eg Oud El Gnauhz Na Uf Gnohc In，Ic Iy Gnauhz Na Gnen Ihz Oud Iuz Uz Om Eg Iem，Iaz Gnib Gnehc Gnim Gniy Gnaix Ed Uz Om Oad Oahz Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Gniq [mods] Uz Om Ed Uf Gnohc Uhc Nahs Gnohz Aij Naij New。</sys:String>

    <sys:String x:Key="OpenGl1282ErrorDetail">It New Naix Uhc Ix Uoy Ihz Oad Gnen Ek Ihz Iac Ouh Gniy Gnaug Ed Gnoy Ihs Ous In，Nauy Iz Ed Iaw E Eix Ehz Uhc Nahs Ihs Gnahc In Iy Naij，Ix Uoy Gnod Iq Iaz Uoh Nar。It New Ed Naug Gnaix Nauy Iz Ix Uoy Uy Eix Iy Euj Eij Iy Ek Gnahc Gnot Ehz。</sys:String>
    <sys:String x:Key="FailedToLoadWorldBecauseOptiFineDetail">Ed Gnoy Ihs Ous Uy Uoy Ihs It New Naix Uhc Gnen Ek Ix Uoy Ed In OptiFine Gnor Naij Ub Ix Uoy Uy Neb Nab（https://www.minecraftforum.net/forums/support/java-edition-support/3051132-exception-ticking-world）。Eix Uom Iaz Iuh Ihz It New Eg Ehz OptiFine Naix Uhc Gnohz Neb Nab，Nauh Gneg In Iy Naij OptiFine Neb Nab Ed，Ix Uoy Gnod Iq Iaz Uoh Nar。Oad Iy Ek In OptiFine Gnauhz Na Gnib Neb Nab Ed Nix Iuz Iaz Aix Nahz Gnaw Gnaf Naug Ed，Ed Neb Nab Iy Gnil Ez Naux Ehz Ouh OptiFine Gnauhz Na Gnix Nij。</sys:String>
    <sys:String x:Key="TextureTooLargeOrLowEndGpuDetail">Gnix Nuy Gnahc Gnehz Af Uw Re Il Uj Nar Naux Ed Oag Oug El Gnoy Ihs Uy Uoy Gnen Ek Ix Uoy Ed In。Eix Iy Id Gnaij Il Uj Nar Naux Gnaij Gnohz Ihz Ehs Ix Uoy Iaz Ihs Gnahc Gniq，Gnaix Naux Gned Il Uj Iaz Aij Iauk Uq Eh Il Uj Ey Ihs Oahs Naij Ur Il。Iaz Nuc Nar Gner It New Oug Ur，Ak Naix Ed Gnen Gnix Oag Gneg Iauk Iy Nauh Gneg Ouh Gnod Uq Ak Naix Ed In Nix Gneg Oay Ux Gnen Ek In。</sys:String>
    <sys:String x:Key="FabricErrorDetail">Fabric Uw Ouc Eg Oud Ouh Eg Iy El Oag Oab Gnen Ek Uoy，Ix Nix Ouc Oab Ed It Uj Nak Ahc Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Ihs Gnahc Gniq。</sys:String>
    <sys:String x:Key="FabricErrorWithSolutionDetail">Fabric Na Gnaf Euj Eij Oail Gnog It Gnen Ek Neh Gnib Uw Ouc Eg Oud Ouh Eg Iy El Oag Oab Gnen Ek Uoy，Ix Nix Ouc Oab Ed It Uj Nak Ahc Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Ihs Gnahc Gniq。</sys:String>
    <sys:String x:Key="ForgeErrorDetail">Forge Uw Ouc Eg Oud Ouh Eg Iy El Oag Oab Gnen Ek Uoy，Ix Nix Ouc Oab Ed It Uj Nak Ahc Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Ihs Gnahc Gniq</sys:String>
    <sys:String x:Key="LegacyForgeDoesNotSupportNewerJavaDetail">Ed In Oug Ur Forge Ib Neb Nab 36.2.26 Id，Nix Gneg Ihs Gnahc Iy Ek In Em An Forge Oad 36.2.26 Neb Nab Oag Gneg Ouh。El Gnoy Ihs Gnij Iy In Oug Ur 36.2.26 Ed Neb Nab Oag Gneg Ouh Forge，Nauh Gneg Oay Ux Gnen Ek In Em An Java Neb Nab。Gnoy Ihs Iaz Forge Ihs，Ahc Naij Iy Uhz Gniq Forge Ed Gnoy Ihs Ous Uy Neb Nab Ed Java Gnor Naij Uof Ihs Neb Nab，Uw Ouc Iel Ic Naix Uhc Naim Ib Iy。</sys:String>
    <sys:String x:Key="MultipleForgeInVersionJsonDetail">El Iag Uix Iq Gnod Iq At Iq El Gnoy Ihs Uy Uoy Ihs Gnen Ek Iuk Gneb Ix Uoy Forge Neb Nab，Gnahc Iy Naij New Ed Neb Nab Naiq Gnad Ihz Oad。It New Eg Ehz Euj Eij El Iew，Gnauhz Na Nix Nauq Ihs Gnahc Gniq Forge，Iag Uix Ial Iq Gnod Iq At Iq Gnoy Ihs Oay Ub Forge Neb Nab。</sys:String>
    <sys:String x:Key="IncompatibleForgeAndOptifineDetail">Iew Niy OptiFine Naiq Gnad Uy Forge Gnor Naij Ub Neb Nab，Iuk Gneb Ix Uoy Ihz Oad。Gnaw Naiq Gniq OptiFine Gnaw Naug（https://optifine.net/downloads）Nak Ahc OptiFine Ed Gnor Naij Forge Neb Nab，Ix Uoy Gnauhz Na Nix Gnohc Neb Nab Gniy Iud Oahz Na Gnib。</sys:String>
    <sys:String x:Key="IncorrectPathEncodingOrMainClassNotFoundDetail">Iab Ihs Iaz Aij Ix Uoy Ihz Oad Iel Uhz Ihs Euq Iauh Nus Gnauhz Na Ix Uoy Uy Uoy Ihs Ouh Am Naib Gnij Ul Ed Euq Gnehz Ub Uy Uoy。Gnohz Ul Um Ed Uf Iz Uhs Et At Iq Ouh New Gnohz Nah Oab Ub Iaz Ihz Gnaf Ul Um Ix Uoy Gnaij Ihs Gnahc Iy Ek Nin，Ix Uoy Eg Ehz Gnauhz Na Nix Gnohc Ihs Gnahc Ehz Ouh。It New Euj Eij Af Uw Nuj It New Ed Gnahs Iy Oug Ur，Oag Oab Ehz Af Iak Gnaix Gniq。</sys:String>
    <sys:String x:Key="ManuallyTriggeredDebugCrashDetail">Iuk Gneb Ihs Oait El Af Uhc Gnod Uohs Nin。</sys:String>
    <sys:String x:Key="ContentValidationFailedDetail">It New Ed Iab Ihs Nay Oaij El Oad Uy Ix Uoy，Ed Ihz Oad It New Oul Gnaw El Naix Uhc Ihs Iaz Aix Uy Uoy Ihs Gnen Ek。Ix Uoy Uhc Nahs Ihs Gnahc Iy Ek In（Uz Om Ouk Oab）Iaz Aix Nix Gnohz Gnib，Gnix Gnid New Ed Eij Nail Oul Gnaw Gnehz Oab Ihs Iaz Aix Nix Gnohc Iaz Ouh。</sys:String>
    <sys:String x:Key="BlockCausedGameCrashDetail">Iuk Gneb El Gnehs Af Ix Uoy Ihz Oad Iauk Gnaf Eg Uom Ed Gnohz Ix Uoy，Ix Nix It Uj Ed Iauk Gnaf Iag Naug Uoy Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Gniq（ID、Gned Oaib Ouz），Iauk Gnaf Iag Uhc Nahs Iq Ij Naib Ut Id Gnoy Ihs Ihs Gnahc Gnib。It New Iag Euj Eij Af Uw Nar Gner Oug Ur，It New At Iq Vl Oak Ihs Ouh Eij Ihs Eg Iy Naij Gnauhc Nix Gnohc Ihs Gnahc Gniq。</sys:String>
    <sys:String x:Key="EntityCausedGameCrashDetail">Iuk Gneb El Gnehs Af Ix Uoy Ihz Oad It Ihs Eg Uom Ed Gnohz Ix Uoy，Ix Nix It Uj Ed It Ihs Iag Naug Uoy Oahz Nux Gnohz Ix Nix Ix Gnaix Ed Gnaf Aix Iaz Gniq（ID、Gned Oaib Ouz），It Ihs Iag Uhc Nahs Iq Ij Naib Ut Id Gnoy Ihs Ihs Gnahc Gnib。It New Iag Euj Eij Af Uw Nar Gner Oug Ur，It New At Iq Vl Oak Ihs Ouh Eij Ihs Eg Iy Naij Gnauhc Nix Gnohc Ihs Gnahc Gniq。</sys:String>
    <sys:String x:Key="LogFileNotFoundDetail">Oag Oab Ix Nef Naij Gnauhc Ial Naij New Ihz Ir Ed Uog Uz Oahs Euq Iq Ix Nef，Ehz Af Iak Ix Nail Ihs Gnahc Gniq。</sys:String>
    <sys:String x:Key="OtherCausedGameCrashDetail">Iuk Gneb Ix Uoy El Ihz Oad Niy Nauy Ed Gnid Euq Ub，Ehz Af Iak Ix Nail Ihs Gnahc Gniq。</sys:String>


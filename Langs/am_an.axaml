    <sys:String x:Key="FailedToReadUpdatedFile">Naij New Nix Gneg Ed Oad Iaz Aix Uq Ud Af Uw，Nix Gneg Gnod Uohs Ihs Gnahc Gniq！</sys:String>
    <sys:String x:Key="DownloadedUpdateDoesNotContainExecutable">Ux Gnehc Gnoy Gniy Nah Oab Ub Gnohz Naij New Nix Gneg Ed Oad Iaz Aix，Nauy Il Naug Gnot Ix Ix Nail Gniq！</sys:String>
    <sys:String x:Key="DownloadedUpdateHashUnmatched">Uf Ub Iq Uy Uy Ihz Ix Ah Ed Naij New Nix Gneg Ed Oad Iaz Aix，Nauy Il Naug Gnot Ix Ix Nail Gniq！</sys:String>
    <sys:String x:Key="FailedToInitFileStream">Uil Naij New Auh Ihs Uhc Af Uw，Nauy Il Naug Gnot Ix Ix Nail Gniq！</sys:String>
    <sys:String x:Key="UnixUpdateDownloadedMessage">Gnehc Naw Iaz Aix Nix Gneg</sys:String>
    <sys:String x:Key="UnixUpdateDownloadedDetailMessage">Oab Ous Ay Nix Gneg Ed Gnehc Naw Iaz Aix Iak Ad Gnid Euq Ij Naid，Ek Ij Ux Gnehc Gnoy Gniy Ed Oal Nauh It Gnod Uohs Uoh Ihz Ay Eij。Uoh Gnid Euq Ij Naid，Uhc Iut Gnod Uhz Gnaij Ux Gnehc。</sys:String>


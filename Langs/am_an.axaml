    <sys:String x:Key="NeoForgedDescription">NeoForged Uy Nauy Eg Iy Ihs Minecraft Forge Ihz Nef Af Iak Ed Nix Ed，Nauy Nef Ub Ad Uoy Forge Naij Uz Nauy Ner Af Iak。</sys:String>
    <sys:String x:Key="QuiltDescription">Quilt Nauy Iak Eg Iy Ihs Um Gnaix、Nail Uj Gnog Gnauhz Iag Ed Gnod Uq Uq Ehs，Iew Oay Uhz Minecraft Ij Ehs。</sys:String>

    <sys:String x:Key="FailedToReadFromClipBoard">Gnor Ien Uq Ud Nab Eiq Naij Gnoc Af Uw。</sys:String>
